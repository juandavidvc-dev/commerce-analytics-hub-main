# Database Configuration
# Use strong passwords in production (min 12 chars, mix of letters, numbers, symbols)
POSTGRES_USER=commerce_user
POSTGRES_PASSWORD=change_me_in_production_strong_password_123!
POSTGRES_DB=commerce_analytics
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Application Configuration
APP_NAME=Commerce Analytics Hub
APP_VERSION=1.0.0
APP_ENV=development

# Security Settings
# Generate random secret keys: openssl rand -hex 32
JWT_SECRET=change_me_jwt_secret_key_minimum_32_characters
ENCRYPTION_KEY=change_me_encryption_key_minimum_32_characters

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# API Configuration (if needed)
API_BASE_URL=http://localhost:3000
API_RATE_LIMIT=100

# Data Processing
BATCH_SIZE=1000
MAX_CONNECTIONS=20

# Docker Configuration
DOCKER_NETWORK=commerce-network
POSTGRES_CONTAINER_NAME=commerce-db

# Monitoring (optional)
ENABLE_METRICS=false
METRICS_PORT=9090
