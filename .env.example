# Configuración de Base de Datos
# Use contraseñas seguras en producción (mínimo 12 caracteres, mezcla de letras, números, símbolos)
POSTGRES_USER=commerce_user
POSTGRES_PASSWORD=change_me_in_production_strong_password_123!
POSTGRES_DB=commerce_analytics
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Configuración de la Aplicación
APP_NAME=Commerce Analytics Hub
APP_VERSION=1.0.0
APP_ENV=development

# Configuración de Seguridad
# Generar claves secretas aleatorias: openssl rand -hex 32
JWT_SECRET=change_me_jwt_secret_key_minimum_32_characters
ENCRYPTION_KEY=change_me_encryption_key_minimum_32_characters

# Configuración de Logs
LOG_LEVEL=info
LOG_FORMAT=json

# Configuración de API (si es necesario)
API_BASE_URL=http://localhost:3000
API_RATE_LIMIT=100

# Procesamiento de Datos
BATCH_SIZE=1000
MAX_CONNECTIONS=20

# Configuración de Docker
DOCKER_NETWORK=commerce-network
POSTGRES_CONTAINER_NAME=commerce-db

# Monitoreo (opcional)
ENABLE_METRICS=false
METRICS_PORT=9090
